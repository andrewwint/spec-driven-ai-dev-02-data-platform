# Customer Data Pipeline .gitignore

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
# IDE / Editor
# =============================================================================
.idea/
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# Testing
# =============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/

# =============================================================================
# Data (keep structure, ignore large files)
# =============================================================================
# Keep the .gitkeep files
!data/**/.gitkeep

# Ignore generated/large data files (uncomment if needed)
# data/cleaned/*.csv
# data/features/*.csv

# =============================================================================
# AWS / Infrastructure
# =============================================================================
*.tfstate
*.tfstate.*
.terraform/
*.zip
lambdas/*.zip

# =============================================================================
# Secrets (NEVER commit these)
# =============================================================================
.env
.env.local
*.pem
*.key
credentials.json
secrets.yaml
