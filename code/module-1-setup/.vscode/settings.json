{
    "editor.formatOnSave": true,
    "editor.rulers": [88, 120],
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "python.analysis.typeCheckingMode": "basic",
    "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
        }
    },
    "[markdown]": {
        "editor.wordWrap": "on",
        "editor.quickSuggestions": {
            "comments": "off",
            "strings": "off",
            "other": "off"
        }
    },
    "files.associations": {
        "*.agent.md": "markdown"
    },
    "github.copilot.chat.codeGeneration.instructions": [
        {
            "text": "Read HISTORY.md for project context before generating code."
        },
        {
            "text": "Check docs/proposals/ for schema contracts before implementing data transformations."
        },
        {
            "text": "Follow the DARE model: Deterministic validation first, then AI-assisted logic."
        }
    ]
}
